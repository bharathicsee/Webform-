<%@ Page Language="C#" AutoEventWireup="true" CodeBehind="Registration.aspx.cs" Inherits="Restrationform.WebForm1" %>

<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.13.1/font/bootstrap-icons.min.css" />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
</head>
<body>
    <style>
        #Registar {
            margin-left: 21em;
            border: solid;
            margin-right: 22em;
            height: 23em;
        } 
        #Registar h1 {
            text-align: center;
        }

        #lblNumber {
            margin-left: 12.5em;
        }


        #lblAge {
            margin-left: 15.5em;
        }

        #CandidateNumber {
            margin-left: 9.5em;
            width: 33%;
            padding: 6px;
            box-sizing: border-box;
        }

        #lblName {
            margin-left: 1em;
        }



        #lblEmailId {
            margin-left: 1em;
        }

        #Age {
            margin-left: 9.5em;
            width: 33%;
            padding: 6px;
            box-sizing: border-box;
        }

        #EmailId {
            margin-left: 1em;
            width: 33%;
            padding: 6px;
            box-sizing: border-box;
        }

        #CandidateName {
            margin-left: 1em;
            width: 33%;
            padding: 6px;
            box-sizing: border-box;
        }

        .styled-textbox {
            width: 280px;
            padding: 10px;
            border: 2px solid #000000;
            border-radius: 6px;
            font-size: 15px;
            font-family: Arial, sans-serif;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

            .styled-textbox:focus {
                border-color: #000000;
                box-shadow: 0 0 6px rgba(46, 139, 87, 0.5);
            }

        .btn-save {
            background-color: #4CAF50;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            margin-left: 14em;
            margin-top: 3em;
