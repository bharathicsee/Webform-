    <form id="form1" runat="server">
        <div>
            <asp:Label ID="Error_Message" runat="server" Text=" "></asp:Label>
            <div id="Registar">
                <h1>Registration From <i class="bi bi-info-circle-fill"></i></h1>
                <hr />
                <asp:Label ID="lblName"><i class="bi bi-person-fill"></i> CandidateName :</asp:Label>
                <asp:Label ID="lblNumber"> <i class="bi bi-telephone-fill"></i> MobileNo :</asp:Label>
                <div>
                    <asp:TextBox ID="CandidateName" runat="server" CssClass="styled-textbox" placeholder="Enter your Name"></asp:TextBox>

                    <asp:TextBox ID="CandidateNumber" runat="server" CssClass="styled-textbox" placeholder="Enter your Number" TextMode="Number"></asp:TextBox>
                    <br />
                    <span id="nameError" style="color: red; margin-left: 1em; display: none;"> Name already exists!</span>
                    
                    <span id="NumberError" style="color: red; margin-left: 12em;  display: none;"> Number already exists!</span>

                </div>
                <br />
                <asp:Label ID="lblEmailId"><i class="bi bi-envelope-open-fill"></i> EmailId :</asp:Label>
                <asp:Label ID="lblAge"> <i class="bi bi-mortarboard-fill"></i> Age :</asp:Label>
                <div>
                    <asp:TextBox ID="EmailId" runat="server" CssClass="styled-textbox" placeholder="Enter your EmailId" AutoPostBack="true" OnTextChanged="EmailId_DataBinding"></asp:TextBox>

                    <asp:TextBox ID="Age" runat="server" CssClass="styled-textbox" placeholder="Enter your Age" TextMode="Number"></asp:TextBox>
                    <asp:Label ID="Label1" Style="MARGIN-LEFT: 2em;" runat="server" Text=" " ></asp:Label>
                </div>
                <asp:Button ID="Button1" runat="server" Text="Save" OnClick="Save" CssClass="btn-save" />
            </div>
        </div>
    </form>
    <script type="text/javascript">$(document).ready(function () {
    // Candidate Name validation
    $("#<%= CandidateName.ClientID %>").blur(function () {
        var name = $(this).val();
        if (name.length > 0) {
            $.ajax({
                type: "POST",
                url: "Registration.aspx/CheckCandidateName",
                data: JSON.stringify({ candidateName: name }),
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {
                    var result = response.d;  
                    if (result.Status) {
                        $("#nameError").text(result.Message).show();
                    } else {
                        $("#nameError").hide();
                    }
                },
                error: function () {
                    alert("Error checking candidate name.");
                }
            });
        }
    });

    // Candidate Number validation
    $("#<%= CandidateNumber.ClientID %>").blur(function () {
        var candidateNumber = $(this).val();
        if (candidateNumber.length > 0) {
            $.ajax({
                type: "POST",
                url: "Registration.aspx/CheckCandidateNumber",
                data: JSON.stringify({ candidateNumber: candidateNumber }), // FIXED
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {
                    var result = response.d; // { Status, Message }
                    if (result.Status) {
                        $("#NumberError").text(result.Message).show();
                    } else {
                        $("#NumberError").hide();
                    }
                },
                error: function () {
                    alert("Error checking candidate number.");
                }
            });
        }
    });
});


</script>
</body>
</html>
