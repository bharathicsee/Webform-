using System;
using System.Collections.Generic;
using System.Linq;
using System.Web;
using System.Web.UI;
using System.Web.UI.WebControls;
using System.Data.SqlClient;
using System.Data;
using System.Configuration;
using System.Web.Services;

namespace Restrationform
{
    public partial class WebForm1 : System.Web.UI.Page
    {
        string connectionString = ConfigurationManager.ConnectionStrings["Restration"].ConnectionString;
        protected void Page_Load(object sender, EventArgs e)
        {

        }
        [WebMethod]
        public static object CheckCandidateName(string candidateName)
        {
            using (SqlConnection conn = new SqlConnection(ConfigurationManager.ConnectionStrings["Restration"].ConnectionString))
            {
                conn.Open();
                using (SqlCommand cmd = new SqlCommand("USP_GetEmailDetails", conn))
                {
                    cmd.CommandType = CommandType.StoredProcedure;

                    cmd.Parameters.AddWithValue("@Data", candidateName);
                    cmd.Parameters.AddWithValue("@Validation", "CondidateName");

                    SqlParameter statusParam = new SqlParameter("@Status", SqlDbType.Bit)
                    {
                        Direction = ParameterDirection.Output
                    };
                    cmd.Parameters.Add(statusParam);

                    SqlParameter messageParam = new SqlParameter("@Messaga", SqlDbType.NVarChar, 500)
                    {
                        Direction = ParameterDirection.Output
                    };
                    cmd.Parameters.Add(messageParam);

                    cmd.ExecuteNonQuery();

                    bool status = (bool)cmd.Parameters["@Status"].Value;
                    string message = cmd.Parameters["@Messaga"].Value.ToString();
                     
                    return new { Status = status, Message = message };
                }
            }
        }

        [WebMethod]
        public static object CheckCandidateNumber(string candidateNumber)
        {
            using (SqlConnection conn = new SqlConnection(ConfigurationManager.ConnectionStrings["Restration"].ConnectionString))
            {
                conn.Open();
                using (SqlCommand cmd = new SqlCommand("USP_GetEmailDetails", conn))
                {
                    cmd.CommandType = CommandType.StoredProcedure;

                    cmd.Parameters.AddWithValue("@Data", candidateNumber);
                    cmd.Parameters.AddWithValue("@Validation", "MobileNo");

                    SqlParameter statusParam = new SqlParameter("@Status", SqlDbType.Bit)
                    {
                        Direction = ParameterDirection.Output
                    };
                    cmd.Parameters.Add(statusParam);

                    SqlParameter messageParam = new SqlParameter("@Messaga", SqlDbType.NVarChar, 500)
                    {
                        Direction = ParameterDirection.Output
                    };
                    cmd.Parameters.Add(messageParam);

                    cmd.ExecuteNonQuery();

                    bool status = (bool)cmd.Parameters["@Status"].Value;
                    string message = cmd.Parameters["@Messaga"].Value.ToString();

                    return new { Status = status, Message = message };
                }
            }
        }



        protected void Save(object sender, EventArgs e)
        {
            try
            {
                SqlConnection con = new SqlConnection(connectionString);

                SqlCommand cmd = new SqlCommand("[dbo].[USP_InsertCondidateDetails]", con);
                cmd.CommandType = CommandType.StoredProcedure;

                cmd.Parameters.Add("@CondidateName", SqlDbType.VarChar).Value = CandidateName.Text;
                cmd.Parameters.Add("@MobileNo", SqlDbType.NVarChar).Value = CandidateNumber.Text;
                cmd.Parameters.Add("@EmailId", SqlDbType.NVarChar).Value = EmailId.Text;
                cmd.Parameters.Add("@Age", SqlDbType.Int).Value = Convert.ToInt32(Age.Text);
                cmd.Parameters.Add("@CompanyId", SqlDbType.NVarChar).Value = 1;

                SqlParameter statusParam = cmd.Parameters.Add("@Status", SqlDbType.Bit);
                statusParam.Direction = ParameterDirection.Output;

                SqlParameter messageParam = cmd.Parameters.Add("@Messaga", SqlDbType.NVarChar, 500);
                messageParam.Direction = ParameterDirection.Output;

                con.Open();
                cmd.ExecuteNonQuery();

                bool statusResult = (bool)statusParam.Value;
                string messageResult = messageParam.Value.ToString();
                if (statusResult == false)
                {
                    Error_Message.Text = messageResult;
                    Error_Message.ForeColor = System.Drawing.Color.Red;
                }
                else
                {
                    Error_Message.Text = messageResult;
                    Error_Message.ForeColor = System.Drawing.Color.Green;
                }


            }
            catch (Exception ex)
            {
                Response.Write(Error_Message.Text = ex.Message);
                Response.Write(Error_Message.ForeColor = System.Drawing.Color.Red);
            }
        }

        protected void EmailId_DataBinding(object sender, EventArgs e)
        {
            try
            {
                SqlConnection con = new SqlConnection(connectionString);

                SqlCommand cmd = new SqlCommand("[dbo].[USP_GetEmailDetails]", con);
                cmd.CommandType = CommandType.StoredProcedure; 
                cmd.Parameters.Add("@Data", SqlDbType.NVarChar).Value = EmailId.Text; 
                cmd.Parameters.Add("@Validation", SqlDbType.NVarChar).Value = "EmailId"; 
                SqlParameter statusParam = cmd.Parameters.Add("@Status", SqlDbType.Bit);
                statusParam.Direction = ParameterDirection.Output;

                SqlParameter messageParam = cmd.Parameters.Add("@Messaga", SqlDbType.NVarChar, 500);
                messageParam.Direction = ParameterDirection.Output;

                con.Open();
                cmd.ExecuteNonQuery();

                bool statusResult = (bool)statusParam.Value;
                string messageResult = messageParam.Value.ToString();
                if (statusResult == false)
                {
                    Label1.Text = messageResult;
                    Label1.ForeColor = System.Drawing.Color.Red;
                } 
                else 
                {
                    Label1.Text = ""; 
                }
                
                

            }
            catch (Exception ex)
            {
                Response.Write(Label1.Text = ex.Message);
                Response.Write(Label1.ForeColor = System.Drawing.Color.Red);
            }
        }
    }
}
